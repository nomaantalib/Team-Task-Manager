# ==========================================
# MONOREPO ENVIRONMENT VARIABLES CONFIG
# ==========================================

# Port for backend MERN server
PORT=5000
NODE_ENV=production

# MongoDB Atlas Cluster Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/task-manager?retryWrites=true&w=majority

# JWT Token Secret for Secure Sessions
JWT_SECRET=your_jwt_signing_secret_key_change_me_in_production
JWT_EXPIRE=30d

# Google Gemini AI developer API Key
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
